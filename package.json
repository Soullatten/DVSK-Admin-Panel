{
  "name": "dvsk-admin-ts",
  "private": true,
  "version": "1.0.8",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:icon": "node build/generate-icon.cjs && node build/generate-installer-art.cjs",
    "electron:tsc": "tsc -p electron && node electron/setup-cjs.cjs",
    "electron:dev": "concurrently --kill-others --names \"vite,electron\" --prefix-colors \"cyan,magenta\" \"npm run dev\" \"wait-on tcp:5172 && npm run electron:tsc && cross-env VITE_DEV_SERVER_URL=http://localhost:5172 electron .\"",
    "electron:build": "npm run electron:icon && vite build && npm run electron:tsc && electron-builder --win",
    "electron:publish": "npm run electron:icon && vite build && npm run electron:tsc && electron-builder --win --publish always"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@shadcn/ui": "^0.0.4",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "electron-updater": "^6.8.3",
    "firebase": "^12.12.1",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "mapbox-gl": "^3.23.0",
    "ogl": "^1.0.11",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-globe.gl": "^2.37.1",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.2.0",
    "socket.io-client": "^4.8.3",
    "styled-components": "^6.4.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "bmp-js": "^0.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.10",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.dvsk.admin",
    "productName": "DVSK Admin",
    "copyright": "© DVSK CLO",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Soullatten",
        "repo": "DVSK-Admin-Panel",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "DVSK Admin Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DVSK Admin",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "runAfterFinish": true,
      "menuCategory": false
    }
  }
}
